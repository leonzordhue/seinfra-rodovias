<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SEINFRA/AM - Rodovias</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        .navbar-brand { font-weight: bold; }
        .rodovia-header { background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%); color: white; }
        .loading { text-align: center; padding: 20px; color: #6c757d; }
        .tab-content { background: #fff; border: 1px solid #dee2e6; border-radius: 0 0 0.375rem 0.375rem; padding: 20px; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="#">
                <i class="fas fa-road me-2"></i>SEINFRA/AM - Rodovias
            </a>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="card shadow-sm">
            <div class="card-header rodovia-header">
                <h5 class="mb-0"><i class="fas fa-route me-2"></i>Consulta de Rodovias Estaduais</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-bold">Selecione a Rodovia:</label>
                    <select id="selectRodovia" class="form-select">
                        <option value="">Carregando rodovias...</option>
                    </select>
                </div>
                <div id="detalhesRodovia" style="display: none;">
                    <div id="rodoviaInfo" class="loading">
                        <i class="fas fa-spinner fa-spin me-2"></i>Carregando detalhes...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="bg-light mt-5 py-3">
        <div class="container text-center">
            <small class="text-muted">Secretaria de Infraestrutura do Amazonas – Dados de Rodovias</small>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // ============================================================
        // CONFIGURAÇÕES – PREENCHA AQUI
        // ============================================================
        const SPREADSHEET_ID = 'SEU_ID_DA_PLANILHA';
        const API_KEY = 'SUA_CHAVE_DE_API';
        const RANGE = 'A:S'; // Colunas de A até S (ajuste se necessário)

        // URL base da API do Google Sheets
        const BASE_URL = `https://sheets.googleapis.com/v4/spreadsheets/${SPREADSHEET_ID}/values/${RANGE}?key=${API_KEY}`;

        // ============================================================
        // CARREGAR TODOS OS DADOS DA PLANILHA
        // ============================================================
        let todasRodovias = []; // array de objetos { rodovia, codigo, extensao, inicio, final, revestimento }

        document.addEventListener('DOMContentLoaded', () => {
            carregarDados();
        });

        async function carregarDados() {
            try {
                const response = await fetch(BASE_URL);
                const data = await response.json();
                if (data.error) {
                    alert('Erro ao acessar planilha: ' + data.error.message);
                    return;
                }

                // data.values é uma matriz: primeira linha = cabeçalho
                const cabecalho = data.values[0];
                const linhas = data.values.slice(1);

                // Mapeia colunas para índices (ajuste conforme sua planilha)
                const idx = {
                    codigo: cabecalho.findIndex(c => c.includes('Código') || c.includes('Código SER/SNV')),
                    rodovia: cabecalho.findIndex(c => c.includes('Rodovia')),
                    extensao: cabecalho.findIndex(c => c.includes('Extensão')),
                    inicio: cabecalho.findIndex(c => c.includes('Início')),
                    final: cabecalho.findIndex(c => c.includes('Final')),
                    revestimento: cabecalho.findIndex(c => c.includes('Tipo de Revestimento'))
                };

                todasRodovias = linhas.map(linha => ({
                    codigo: linha[idx.codigo] || '',
                    rodovia: linha[idx.rodovia] || '',
                    extensao: linha[idx.extensao] || '',
                    inicio: linha[idx.inicio] || '',
                    final: linha[idx.final] || '',
                    revestimento: linha[idx.revestimento] || ''
                })).filter(item => item.rodovia); // remove linhas sem rodovia

                // Preenche o select com nomes únicos de rodovias
                const rodoviasUnicas = [...new Set(todasRodovias.map(r => r.rodovia))].sort();
                const select = document.getElementById('selectRodovia');
                select.innerHTML = '<option value="">Selecione uma rodovia</option>';
                rodoviasUnicas.forEach(nome => {
                    const option = document.createElement('option');
                    option.value = nome;
                    option.textContent = nome;
                    select.appendChild(option);
                });

                select.addEventListener('change', (e) => {
                    const nome = e.target.value;
                    if (nome) mostrarRodovia(nome);
                    else document.getElementById('detalhesRodovia').style.display = 'none';
                });

            } catch (error) {
                console.error('Erro ao carregar dados:', error);
                document.getElementById('selectRodovia').innerHTML = '<option value="">Erro ao carregar</option>';
            }
        }

        function mostrarRodovia(nome) {
            const container = document.getElementById('rodoviaInfo');
            container.innerHTML = '<div class="loading"><i class="fas fa-spinner fa-spin me-2"></i>Carregando...</div>';
            document.getElementById('detalhesRodovia').style.display = 'block';

            const trechos = todasRodovias.filter(r => r.rodovia === nome);
            const extensaoTotal = trechos.reduce((acc, t) => acc + (parseFloat(t.extensao) || 0), 0).toFixed(2);

            let html = `
                <div class="card">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-route me-2"></i>${nome}</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <p><strong>Extensão Total:</strong> ${extensaoTotal} km</p>
                            </div>
                            <div class="col-md-6">
                                <p><strong>Total de Trechos:</strong> ${trechos.length}</p>
                            </div>
                        </div>
                        <h6 class="border-bottom pb-2">Trechos da Rodovia:</h6>
                        <div class="table-responsive">
                            <table class="table table-striped table-sm">
                                <thead>
                                    <tr>
                                        <th>Código</th>
                                        <th>Extensão (km)</th>
                                        <th>Início</th>
                                        <th>Final</th>
                                        <th>Revestimento</th>
                                    </tr>
                                </thead>
                                <tbody>
            `;

            trechos.forEach(t => {
                html += `
                    <tr>
                        <td>${t.codigo}</td>
                        <td>${t.extensao}</td>
                        <td>${t.inicio}</td>
                        <td>${t.final}</td>
                        <td>${t.revestimento}</td>
                    </tr>
                `;
            });

            html += `
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            `;

            container.innerHTML = html;
        }
    </script>
</body>
</html>
